{
  "name": "relay-cli",
  "version": "0.1.0",
  "description": "Command-line interface for relay.link — quote, bridge, and swap across chains from your terminal.",
  "type": "module",
  "bin": {
    "relay": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/index.mjs",
    "relay": "node dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@relayprotocol/relay-bitcoin-wallet-adapter": "^17.0.8",
    "@relayprotocol/relay-sdk": "^5.2.7",
    "@relayprotocol/relay-svm-wallet-adapter": "^18.0.7",
    "@solana/web3.js": "1.98.2",
    "bitcoinjs-lib": "^7.0.1",
    "bs58": "^6.0.0",
    "commander": "^14.0.3",
    "ecpair": "^3.0.1",
    "picocolors": "^1.1.1",
    "tiny-secp256k1": "^2.2.4",
    "viem": "^2.49.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bigint-buffer",
      "bufferutil",
      "keccak",
      "tiny-secp256k1",
      "utf-8-validate"
    ]
  }
}
